# Публичный адрес в vless:// (если inbound listen=0.0.0.0 — иначе часто не нужен)
# PANEL_CLIENT_LINK_HOST=vpn.example.com

# Опционально: база для /sub/… (не показывается пользователю в основной выдаче)
# SUBSCRIPTION_PUBLIC_BASE_URL=https://vpn.example.com:2096
# Опционально: другой inbound для второго устройства
# SECOND_DEVICE_INBOUND_ID=2

# Публичный URL для ссылок подписки (если отличается от PANEL_BASE_URL)
# SUBSCRIPTION_PUBLIC_BASE_URL=https://your-domain:2096

# Режим второго ключа: manual_approval | auto
SECOND_KEY_MODE=manual_approval

# Регенерация: cooldown (сек) и лимит в сутки
REGENERATE_COOLDOWN_SEC=300
REGENERATE_MAX_PER_DAY=5

# Не трогать ключ в панели при bind (рекомендуется false)
PANEL_UPDATE_REMARK_ON_BIND=false

# VLESS flow в addClient (по умолчанию в коде: xtls-rprx-vision). Пустая строка PANEL_CLIENT_FLOW= — не слать flow.
# PANEL_CLIENT_FLOW=xtls-rprx-vision

# При необходимости поправьте пути API под вашу версию 3x-ui
# PANEL_LOGIN_PATH=/login
# PANEL_API_LIST_INBOUNDS=/panel/api/inbounds/list
# PANEL_API_ADD_CLIENT=/panel/api/inbounds/addClient
# PANEL_API_UPDATE_CLIENT=/panel/api/inbounds/updateClient
# PANEL_API_DEL_CLIENT=/panel/api/inbounds/delClientByEmail
# Трафик: один клиент на запрос — {email} = panel client email (не inbound id)
# PANEL_API_CLIENT_TRAFFIC=/panel/api/inbounds/getClientTraffics/{email}

LOG_LEVEL=INFO
